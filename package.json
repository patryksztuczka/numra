{
  "name": "numra",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "check": "pnpm format:check && pnpm lint && pnpm deps:check && pnpm typecheck",
    "check:fix": "pnpm lint:fix && pnpm format && syncpack fix-mismatches --dependency-types prod,dev,peer && syncpack format",
    "clean": "turbo run clean && rm -rf .turbo",
    "deps:check": "syncpack lint --dependency-types prod,dev,peer",
    "dev": "turbo run dev",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --deny-warnings .",
    "lint:fix": "oxlint --fix --deny-warnings .",
    "prepare": "lefthook install",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "lefthook": "2.1.10",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "0.25.0",
    "syncpack": "15.3.2",
    "turbo": "2.10.5",
    "typescript": "catalog:"
  },
  "engines": {
    "node": "26.4.0",
    "pnpm": "11.9.0"
  },
  "packageManager": "pnpm@11.9.0"
}
