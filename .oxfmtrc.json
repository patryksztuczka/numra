{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": ["dist/**", "coverage/**", ".turbo/**", ".wrangler/**"],
  "printWidth": 100,
  "semi": true,
  "singleQuote": false,
  "sortImports": true,
  "sortPackageJson": {
    "sortScripts": true
  },
  "sortTailwindcss": {
    "stylesheet": "./apps/web/src/styles.css"
  },
  "trailingComma": "all"
}
